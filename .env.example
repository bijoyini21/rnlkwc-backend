# ── Required ───────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017         # or your MongoDB Atlas URI
DB_NAME=rnlkwc_chatbot
OPENAI_API_KEY=sk-...                      # your OpenAI key (get from platform.openai.com)
JWT_SECRET=change-this-to-a-long-random-string

# ── Optional ───────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (default: * = all)
CORS_ORIGINS=https://chat.rnlkwc.ac.in,http://localhost:3000
